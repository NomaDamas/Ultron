# Ultron environment configuration example.
# Copy to .env (which is gitignored) OR configure at runtime with no code edits via:
#   python -m ultron.config set llm.api_key --stdin     (secrets, no echo)
#   python -m ultron.config set llm.model gpt-4o-mini    (non-secret values)
#   python -m ultron.config status                       (redacted view)
# Or the write-only Model settings panel on /dashboard.
#
# Precedence (highest first): runtime secret store > process env > .env.
# Default mode needs NO keys (deterministic fakes); live mode is opt-in below.

# --- Mode selection (default: fake; all stay green with no keys) ---
# ULTRON_ADAPTER=fake             # fake | pinned-hermes
# ULTRON_UI_GENERATOR=fake        # fake | model  (model-driven GenUI)
# ULTRON_MODULE_SYNTH=fake        # fake | model
# ULTRON_VLM=fake                 # fake | model  (vision/multimodal)

# --- LLM (text) provider, OpenAI-compatible ---
# ULTRON_LLM_BASE_URL=https://api.openai.com/v1
# ULTRON_LLM_API_KEY=sk-...
# ULTRON_LLM_MODEL=gpt-4o-mini

# --- VLM (vision/multimodal) provider, OpenAI-compatible ---
# ULTRON_VLM_BASE_URL=https://api.openai.com/v1
# ULTRON_VLM_API_KEY=sk-...
# ULTRON_VLM_MODEL=gpt-4o

# --- Out-of-repo secret/config store location (optional override) ---
# ULTRON_CONFIG_DIR=~/.config/ultron

# --- Live env-gated tests (skipped unless set) ---
# ULTRON_LIVE_MODEL=1
